{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["student", "reviewer", "admin", "ydp"] },
        "name": { "type": "string" },
        "matricNumber": { "type": "string" },
        "college": { "type": "string" },
        "faculty": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "name"]
    },
    "Application": {
      "title": "Program Application",
      "description": "Stores details of student program applications.",
      "type": "object",
      "properties": {
        "applicantId": { "type": "string", "description": "UID of the student" },
        "applicantPosition": { "type": "string", "enum": ["Pengarah", "Setiausaha"] },
        "title": { "type": "string" },
        "startDate": { "type": "string", "description": "Program start date" },
        "endDate": { "type": "string", "description": "Program end date" },
        "status": { 
          "type": "string", 
          "enum": ["Draf", "Menunggu Semakan", "Perlu Pembetulan", "Menunggu Pembentangan", "Menunggu Kelulusan YDP", "Diluluskan", "Ditolak"] 
        },
        "budget": { "type": "number" },
        "category": { "type": "string" },
        "objective": { "type": "string" },
        "academicSession": { "type": "string" },
        "semester": { "type": "string" },
        "paperUrl": { "type": "string", "description": "URL to the uploaded paper" },
        "presentationSessionId": { "type": "string", "description": "ID of the assigned presentation session" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["applicantId", "title", "status", "createdAt"]
    },
    "Settings": {
      "title": "System Settings",
      "description": "Stores global system settings like categories.",
      "type": "object",
      "properties": {
        "list": { "type": "array", "items": { "type": "string" } }
      }
    },
    "PresentationSession": {
      "title": "Presentation Session",
      "description": "Stores available slots for program presentations.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Open", "Closed"] }
      },
      "required": ["name", "startDate", "endDate", "status"]
    },
    "Report": {
      "title": "Post-Program Report",
      "description": "Stores post-program reports and financial receipts.",
      "type": "object",
      "properties": {
        "applicationId": { "type": "string" },
        "applicantId": { "type": "string" },
        "status": { "type": "string", "enum": ["Tertunggak", "Dihantar", "Disahkan", "Perlu Pembetulan"] },
        "reportUrl": { "type": "string" },
        "receiptUrl": { "type": "string" },
        "unionBudgetUsed": { "type": "number", "description": "Amount of finance used from the Student Union" },
        "verifiedBudgetUsed": { "type": "number", "description": "Amount of finance verified by the Reporting Unit" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "reviewedAt": { "type": "string", "format": "date-time" },
        "reviewerComment": { "type": "string" }
      },
      "required": ["applicationId", "applicantId", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "applications/{applicationId}": {
      "schema": "Application",
      "description": "Collection of program applications."
    },
    "presentationSessions/{sessionId}": {
      "schema": "PresentationSession",
      "description": "Collection of presentation sessions."
    },
    "reports/{reportId}": {
      "schema": "Report",
      "description": "Collection of post-program reports."
    },
    "settings/{settingId}": {
      "schema": "Settings",
      "description": "Collection for system settings (e.g., categories)."
    }
  }
}
